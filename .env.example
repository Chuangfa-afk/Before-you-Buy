# Auto.dev: live retail prices for the price bar (get key at https://www.auto.dev)
AUTO_DEV_API_KEY=your_auto_dev_api_key_here

# Groq for AI Analysis - fast inference (get key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
# Optional: GROQ_MODEL=llama-3.3-70b-versatile (default)
# Rate limit retry: GROQ_RATE_LIMIT_MAX_RETRIES=3, GROQ_RATE_LIMIT_BASE_DELAY=5, GROQ_RATE_LIMIT_MAX_DELAY=60

# Google Gemini (AI Studio) - fallback if Groq not set (get key at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: GEMINI_MODEL=gemini-2.0-flash (default)

# OpenAI (or compatible API) - fallback if Groq/Gemini not set
OPENAI_API_KEY=your_openai_api_key_here
# Optional: OPENAI_MODEL=gpt-4o-mini (default)
# Optional: OPENAI_BASE_URL for Azure or other OpenAI-compatible endpoints

# EPA fuel economy + fuel prices are used automatically (no key).

